{
  "productName": "Tablerreur",
  "identifier": "com.tablerreur.desktop",
  "version": "0.1.0",
  "build": {
    "frontendDist": "./frontend"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tablerreur",
        "width": 1500,
        "height": 960,
        "url": "about:blank"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/tablerreur-backend-x86_64-pc-windows-msvc/**/*"
    ],
    "windows": {
      "wix": {
        "language": "fr-FR"
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
